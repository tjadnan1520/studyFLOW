# StudyFlow - Environment Configuration
# Copy this file to .env and update values

# Database Configuration
DB_HOST=localhost
DB_NAME=studyflow
DB_USER=root
DB_PASS=

# App Configuration
APP_NAME=StudyFlow
APP_URL=http://localhost/website
APP_DEBUG=true

# File Upload
MAX_UPLOAD_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx,txt,jpg,jpeg,png,zip
